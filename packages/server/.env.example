# Server Configuration
PORT=4000
NODE_ENV=development

# Database
DB_PATH=./data/code-link.db

# =============================================================================
# REQUIRED SECURITY VARIABLES
# =============================================================================

# JWT Secret (REQUIRED - must be at least 32 characters)
# Generate with: openssl rand -base64 32
# Production will NOT start without this!
JWT_SECRET=your-jwt-secret-key-must-be-at-least-32-characters!

# Admin Password (REQUIRED in production)
# Production environments must set this - no default password!
ADMIN_PASSWORD=secure-admin-password

# =============================================================================
# CORS Configuration (REQUIRED for security)
# =============================================================================

# Single origin (development default)
CORS_ORIGIN=http://localhost:3000

# Multiple origins for production (comma-separated)
# CORS_ORIGINS=http://localhost:3000,https://app.example.com

# =============================================================================
# Optional Configuration
# =============================================================================

# Admin Email (default: admin@example.com)
ADMIN_EMAIL=admin@example.com

# Super Admin Emails (comma-separated, full permissions)
SUPER_ADMIN_EMAILS=admin@example.com

# Claude Config Encryption Key (optional, for user config encryption)
# Generate with: openssl rand -base64 32
CLAUDE_CONFIG_ENCRYPTION_KEY=your-encryption-key-here

# Anthropic API Key (optional, for AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# OAuth Configuration (optional)
# =============================================================================

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab OAuth
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com

# OAuth Redirect URI
OAUTH_REDIRECT_URI=http://localhost:4000/oauth/callback

# =============================================================================
# Docker/Container Configuration
# =============================================================================

# Preview Container
PREVIEW_HOST=localhost

# Docker Volumes
VOLUMES_DIR=./volumes
