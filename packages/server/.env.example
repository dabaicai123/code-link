# Server Configuration
PORT=4000
NODE_ENV=development

# Database
DB_PATH=./data/code-link.db

# JWT Secret (required for authentication)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-here

# Claude Config Encryption Key (required for user config encryption)
# Must be at least 32 characters
# Generate with: openssl rand -base64 32
CLAUDE_CONFIG_ENCRYPTION_KEY=your-encryption-key-here

# Anthropic API Key (required for AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab OAuth (optional)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com

# OAuth Redirect URI
OAUTH_REDIRECT_URI=http://localhost:4000/oauth/callback

# Preview Container
PREVIEW_HOST=localhost

# Docker Volumes
VOLUMES_DIR=./volumes

# 超级管理员邮箱列表（逗号分隔）
# 超级管理员拥有所有组织的最高权限，可以创建新组织
SUPER_ADMIN_EMAILS=admin@example.com,admin2@example.com
